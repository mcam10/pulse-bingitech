---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Newsletter from '../components/Newsletter.astro';
---
<Base title="Home" description="Data-driven Caribbean intelligence — tourism, economics, and culture insights from BingiTech.">
  <section class="hero">
    <div class="container">
      <span class="hero-tag">Caribbean Intelligence</span>
      <h1>Data tells the real story.</h1>
      <p>Tourism trends, economic signals, and cultural insights from across the Caribbean — backed by numbers, not narratives.</p>
    </div>
  </section>

  <section class="articles container">
    <h2 class="section-title">Latest</h2>
    <div class="grid">
      <ArticleCard
        title="Is Jamaica Safe to Visit in 2026? What the Arrival Data Actually Says"
        excerpt="3.7M visitors through Nov 2025 despite Hurricane Melissa. Here's what the numbers reveal about safety and demand."
        href="/articles/jamaica-safe-2026"
        date="June 2026"
      />
    </div>
  </section>

  <div class="container">
    <Newsletter />
  </div>
</Base>

<style>
  .hero {
    background: var(--green);
    padding: 5rem 0 4rem;
    text-align: center;
  }
  .hero-tag {
    display: inline-block;
    background: var(--gold);
    color: var(--green-dark);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }
  .hero h1 {
    color: var(--white);
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.5px;
  }
  .hero p {
    color: var(--white);
    opacity: 0.85;
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }
  .articles {
    padding-top: 3rem;
  }
  .section-title {
    font-size: 1.25rem;
    color: var(--green);
    margin-bottom: 1.5rem;
    border-bottom: 2px solid var(--gold);
    display: inline-block;
    padding-bottom: 0.25rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
</style>
