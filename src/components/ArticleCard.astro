---
interface Props {
  title: string;
  excerpt: string;
  href: string;
  date: string;
}

const { title, excerpt, href, date } = Astro.props;
---
<a href={href} class="card">
  <span class="card-date">{date}</span>
  <h3 class="card-title">{title}</h3>
  <p class="card-excerpt">{excerpt}</p>
  <span class="card-link">Read more &rarr;</span>
</a>

<style>
  .card {
    display: block;
    background: white;
    border: 1px solid var(--gray);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .card:hover {
    border-color: var(--gold);
    box-shadow: 0 4px 12px rgba(27, 94, 66, 0.08);
  }
  .card-date {
    font-size: 0.8rem;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .card-title {
    font-size: 1.15rem;
    margin: 0.5rem 0;
    color: var(--green);
    line-height: 1.3;
  }
  .card-excerpt {
    font-size: 0.9rem;
    color: var(--text-light);
    margin-bottom: 1rem;
  }
  .card-link {
    font-size: 0.85rem;
    color: var(--gold);
    font-weight: 600;
  }
</style>
